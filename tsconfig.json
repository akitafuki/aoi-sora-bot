{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["node", "jest"],
    "paths": {
      "@atproto/api": ["./node_modules/@atproto/api/dist/index.d.ts"]
    }
  },
  "exclude": ["prisma.config.ts", "tests"]
}